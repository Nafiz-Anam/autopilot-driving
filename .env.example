# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=autopilot
POSTGRES_PASSWORD=autopilot_secret
POSTGRES_DB=autopilot

# ── pgAdmin (profile: tools) ─────────────────────────────────────────────────
PGADMIN_EMAIL=admin@autopilot.local
PGADMIN_PASSWORD=admin

# ── Backend bridge JWT (must match backend NEXTAUTH_BRIDGE_SECRET) ────────────
NEXTAUTH_BRIDGE_SECRET=change-me-bridge-openssl-rand-base64-32-chars-min

# ── URLs ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3008
NEXT_PUBLIC_BACKEND_API_BASE_URL=http://localhost:8008/v1
