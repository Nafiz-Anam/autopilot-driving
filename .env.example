# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=autopilot
POSTGRES_PASSWORD=autopilot_secret
POSTGRES_DB=autopilot

# ── pgAdmin (profile: tools) ─────────────────────────────────────────────────
PGADMIN_EMAIL=admin@autopilot.local
PGADMIN_PASSWORD=admin

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3008
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# ── URLs ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3008
NEXT_PUBLIC_BACKEND_URL=http://localhost:8008
