# Postgres
POSTGRES_USER=autopilot
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=autopilot_staging

# Redis
REDIS_PASSWORD=
REDIS_DB=0

# Public URLs (Traefik fronts driving.agiloit.com / api.driving.agiloit.com)
NEXT_PUBLIC_APP_URL=https://driving.agiloit.com
NEXT_PUBLIC_BACKEND_API_BASE_URL=https://api.driving.agiloit.com/v1

# NextAuth
NEXTAUTH_URL=https://driving.agiloit.com
NEXTAUTH_SECRET=replace-with-long-random-secret
NEXTAUTH_BRIDGE_SECRET=replace-with-long-random-secret

# Backend JWT
JWT_SECRET=replace-with-long-random-jwt-secret
JWT_ACCESS_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Google Places (optional)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
