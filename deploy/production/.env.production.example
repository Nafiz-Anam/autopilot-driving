# ============================================================================
# AutoPilot Driving — Production Environment Variables
# ============================================================================
# Copy this file to .env.production and fill in with real values.
# Never commit .env.production to git — it contains secrets.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=autopilot_prod
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=autopilot_prod

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_DB=0

# ── Frontend URLs ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://autopilotdrivingschool.co.uk
NEXT_PUBLIC_BACKEND_API_BASE_URL=https://api.autopilotdrivingschool.co.uk/v1

# ── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://autopilotdrivingschool.co.uk
NEXTAUTH_SECRET=change_me_nextauth_secret_at_least_32_chars
NEXTAUTH_BRIDGE_SECRET=change_me_bridge_secret_at_least_32_chars

# ── Backend JWT ─────────────────────────────────────────────────────────────
JWT_SECRET=change_me_jwt_secret
JWT_ACCESS_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10

# ── SMTP ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@autopilotdrivingschool.co.uk

# ── Google Places API ───────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=your_google_places_api_key
GOOGLE_PLACE_ID=your_google_place_id
