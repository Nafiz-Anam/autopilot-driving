datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  phone         String?
  image         String?
  passwordHash  String?
  role          Role      @default(STUDENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  bookings      Booking[] @relation("StudentBookings")
  instructor    Instructor?
  theoryProgress StudentTheoryProgress[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Instructor {
  id            String         @id @default(cuid())
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id])
  bio           String?
  photoUrl      String?
  rating        Float          @default(5.0)
  reviewCount   Int            @default(0)
  yearsExp      Int            @default(1)
  transmission  String[]
  areas         String[]
  pricePerHour  Decimal        @db.Decimal(10, 2)
  isFemale      Boolean        @default(false)
  isActive      Boolean        @default(true)
  licenceNumber String?
  createdAt     DateTime       @default(now())
  bookings      Booking[]
  availability  Availability[]
}

model Availability {
  id           String     @id @default(cuid())
  instructorId String
  instructor   Instructor @relation(fields: [instructorId], references: [id])
  dayOfWeek    Int
  startTime    String
  endTime      String
  isAvailable  Boolean    @default(true)
}

model Booking {
  id              String        @id @default(cuid())
  reference       String        @unique @default(cuid())
  studentId       String
  student         User          @relation("StudentBookings", fields: [studentId], references: [id])
  instructorId    String
  instructor      Instructor    @relation(fields: [instructorId], references: [id])
  lessonType      LessonType
  transmission    String
  scheduledAt     DateTime
  durationMins    Int           @default(60)
  status          BookingStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  stripePaymentId String?
  totalAmount     Decimal       @db.Decimal(10, 2)
  pricingPackageId String?
  pricingPackage   LessonPricingPackage? @relation(fields: [pricingPackageId], references: [id], onDelete: SetNull)
  voucherCode     String?
  couponCode      String?
  discountAmount  Decimal?      @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

/// One row per `LessonType` — admin-editable labels and marketing copy for pricing surfaces.
model LessonPricingCategory {
  id          String                 @id @default(cuid())
  lessonType  LessonType             @unique
  slug        String
  displayName String
  description String?
  sortOrder   Int                    @default(0)
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  packages    LessonPricingPackage[]
}

/// Bookable packages shown on /prices, lesson pages, and booking step 3.
model LessonPricingPackage {
  id           String                 @id @default(cuid())
  categoryId   String
  category     LessonPricingCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  slug         String
  name         String
  hours        Int
  lessons      Int                    @default(1)
  price        Decimal                @db.Decimal(10, 2)
  pricePerHour Decimal?               @db.Decimal(10, 2)
  savings      Decimal?               @db.Decimal(10, 2)
  footerNote   String?
  badge        String?
  isPopular    Boolean                @default(false)
  sortOrder    Int                    @default(0)
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  bookings     Booking[]

  @@unique([categoryId, slug])
  @@index([categoryId, isActive, sortOrder])
}

model Coupon {
  id                String    @id @default(cuid())
  code              String    @unique
  name              String?
  type              CouponType
  value             Decimal   @db.Decimal(10, 2)
  maxDiscountAmount Decimal?  @db.Decimal(10, 2)
  minOrderAmount    Decimal?  @db.Decimal(10, 2)
  startsAt          DateTime?
  endsAt            DateTime?
  maxRedemptions    Int?
  redemptionCount   Int       @default(0)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model GiftVoucher {
  id              String   @id @default(cuid())
  code            String   @unique
  amount          Decimal  @db.Decimal(10, 2)
  balance         Decimal  @db.Decimal(10, 2)
  isRedeemed      Boolean  @default(false)
  senderName      String
  recipientName   String
  recipientEmail  String
  message         String?
  stripePaymentId String?
  expiresAt       DateTime
  createdAt       DateTime @default(now())
}

model InstructorApplication {
  id              String   @id @default(cuid())
  fullName        String
  email           String
  phone           String
  postcode        String
  hasFullLicence  Boolean
  yearsExperience String
  trainingStarted Boolean  @default(false)
  message         String?
  status          String   @default("pending")
  createdAt       DateTime @default(now())
}

model TheoryQuestion {
  id           String                  @id @default(cuid())
  category     String
  question     String
  options      Json
  correctIndex Int
  explanation  String?
  imageUrl     String?
  attempts     StudentTheoryProgress[]
}

model StudentTheoryProgress {
  id          String         @id @default(cuid())
  studentId   String
  student     User           @relation(fields: [studentId], references: [id])
  questionId  String
  question    TheoryQuestion @relation(fields: [questionId], references: [id])
  isCorrect   Boolean
  attemptedAt DateTime       @default(now())

  @@index([studentId])
}

model Area {
  id             String  @id @default(cuid())
  name           String
  postcodePrefix String
  description    String?
  isActive       Boolean @default(true)
}

model ContactSubmission {
  id          String   @id @default(cuid())
  name        String
  phone       String
  postcode    String
  enquiryType String
  callTime    String?
  message     String?
  createdAt   DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum LessonType {
  MANUAL
  AUTOMATIC
  INTENSIVE
  REFRESHER
  PASS_PLUS
  THEORY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  PARTIAL_REFUND
}

enum CouponType {
  PERCENT
  FIXED
}
