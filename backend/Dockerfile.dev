# Development image — hot-reload via nodemon
FROM node:22-slim

RUN apt-get update && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN npm install -g pnpm

COPY package.json pnpm-lock.yaml ./
COPY prisma ./prisma

RUN pnpm install
RUN pnpm dlx prisma generate

COPY . .

EXPOSE 8000

CMD ["pnpm", "dev"]
